# Copy to .env and fill in. .env is gitignored. These are read only by the
# Node server (server/*.js); they are never bundled into the frontend.

# --- Spotify ---------------------------------------------------------------
# From https://developer.spotify.com/dashboard (create an app).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Obtained once by running: node server/get-spotify-token.js
SPOTIFY_REFRESH_TOKEN=
# Redirect URI registered in the Spotify app settings (used only by the helper).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# short_term (~4 weeks), medium_term (~6 months), or long_term (all time).
SPOTIFY_TIME_RANGE=short_term
SPOTIFY_LIMIT=4

# --- Steam -----------------------------------------------------------------
# Key from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Your 64-bit SteamID (find it at https://steamid.io).
STEAM_ID=
STEAM_LIMIT=4

# --- Server ----------------------------------------------------------------
PORT=3001
# How long to cache Spotify/Steam responses before refetching.
STATS_CACHE_MINUTES=10
